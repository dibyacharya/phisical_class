{
  "name": "lecture-capture-backend",
  "version": "1.0.0",
  "description": "Lecture Capture System - Backend API",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "test": "jest --forceExit --detectOpenHandles --verbose",
    "test:watch": "jest --watch --forceExit --detectOpenHandles"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFiles": ["<rootDir>/tests/setup.js"],
    "testTimeout": 30000,
    "verbose": true
  },
  "dependencies": {
